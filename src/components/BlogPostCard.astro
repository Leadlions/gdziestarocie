---
interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  tags?: string[];
  href: string;
}

const { title, description, publishedAt, tags, href } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a href={href} class="group block rounded-xl border border-stone-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
  {tags?.length && (
    <div class="mb-2 flex flex-wrap gap-1.5">
      {tags.slice(0, 2).map((tag) => (
        <span class="inline-block rounded-full bg-stone-100 px-2.5 py-0.5 text-xs font-medium text-stone-600">
          {tag}
        </span>
      ))}
    </div>
  )}
  <h3 class="font-semibold text-stone-800 transition-colors group-hover:text-brand-700">
    {title}
  </h3>
  <p class="mt-1.5 text-sm leading-relaxed text-stone-500 line-clamp-2">{description}</p>
  <p class="mt-3 text-xs text-stone-400">{formattedDate}</p>
</a>
