---
interface Review {
  author: string;
  rating: number;
  text: string;
  date: string;
}

interface Props {
  slug: string;
  name: string;
  city: string;
  venue: string;
  nextDate: string;
  recurringDesc?: string | null;
  categories: string[];
  reviews: Review[];
}

const { slug, name, city, venue, nextDate, recurringDesc, categories, reviews } = Astro.props;

const avgRating =
  reviews.length > 0
    ? reviews.reduce((s, r) => s + r.rating, 0) / reviews.length
    : null;

const CATEGORY_LABELS: Record<string, string> = {
  antyki: 'Antyki',
  meble: 'Meble',
  ceramika: 'Ceramika',
  bizuteria: 'Biżuteria',
  numizmatyka: 'Numizmatyka',
  ksiazki: 'Książki',
  zabawki: 'Zabawki',
  militaria: 'Militaria',
  obrazy: 'Obrazy',
  winyle: 'Winyle',
};

const formattedDate = new Date(nextDate).toLocaleDateString('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const reviewLabel =
  reviews.length === 1 ? '1 opinia' : reviews.length < 5 ? `${reviews.length} opinie` : `${reviews.length} opinii`;
---

<div class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="mb-2 flex flex-wrap gap-1.5">
        {categories.slice(0, 3).map((cat) => (
          <span class="inline-block rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-medium text-brand-800">
            {CATEGORY_LABELS[cat] ?? cat}
          </span>
        ))}
      </div>

      <a href={`/targi/${slug}/`} class="group">
        <h3 class="font-semibold text-stone-800 transition-colors group-hover:text-brand-700">
          {name}
        </h3>
      </a>

      <p class="mt-1 text-sm text-stone-500">
        <span class="font-medium text-stone-700">{formattedDate}</span>
        &middot; {city}
      </p>
      <p class="mt-0.5 text-xs text-stone-400">{venue}</p>

      {recurringDesc && (
        <p class="mt-1 text-xs font-medium text-brand-700">↻ {recurringDesc}</p>
      )}

      {avgRating !== null && (
        <p class="mt-1.5 text-sm font-medium text-amber-500">
          {'★'.repeat(Math.round(avgRating))}{'☆'.repeat(5 - Math.round(avgRating))}
          <span class="ml-1 font-normal text-stone-500">
            {avgRating.toFixed(1)} ({reviewLabel})
          </span>
        </p>
      )}
    </div>

    <a
      href={`/targi/${slug}/`}
      class="shrink-0 rounded-md bg-brand-50 px-3 py-1.5 text-xs font-semibold text-brand-700 transition-colors hover:bg-brand-100"
    >
      Szczegóły →
    </a>
  </div>
</div>
