function getColor(count: number): string {
  if (count === 0) return '#f5f0eb';
  if (count === 1) return '#fde68a';
  if (count === 2) return '#fbbf24';
  if (count <= 4) return '#f59e0b';
  return '#d97706';
}

function getTextColor(count: number): string {
  return count >= 2 ? '#78350f' : '#92400e';
}
---

<div class="relative w-full max-w-2xl mx-auto select-none" id="woj-map-wrap">
  <!-- Tooltip -->
  <div
    id="woj-tooltip"
    class="pointer-events-none absolute z-10 hidden rounded-lg bg-stone-900 px-3 py-2 text-sm text-white shadow-xl"
    style="transform: translate(-50%, -110%)"
  >
    <span id="woj-tooltip-name" class="font-semibold"></span>
    <span id="woj-tooltip-count" class="ml-2 text-amber-300"></span>
    <div class="absolute left-1/2 top-full -translate-x-1/2 border-4 border-transparent border-t-stone-900"></div>
  </div>

  <svg
    viewBox="0 0 650 490"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full"
    id="woj-map"
  >
    {VOIVODESHIPS.map((woj) => {
      const count = fairCounts[woj.slug] ?? 0;
      const fill = getColor(count);
      const textCol = getTextColor(count);
      return (
        <g
          class="woj-region cursor-pointer"
          data-slug={woj.slug}
          data-name={woj.name}
          data-count={count}
        >
          <path
            d={woj.path}
            fill={fill}
            stroke="#d6c9b8"
            stroke-width="2"
            stroke-linejoin="round"
            class="transition-all duration-150"
          />
          <text
            x={woj.lx}
            y={woj.ly}
            text-anchor="middle"
            font-size="10"
            font-family="system-ui, sans-serif"
            font-weight="600"
            fill={textCol}
            class="pointer-events-none"
          >
            {count}
          </text>
        </g>
      );
    })}
  </svg>

  <!-- Legenda -->
  <div class="mt-3 flex items-center justify-center gap-4 text-xs text-stone-500">
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded" style="background:#f5f0eb;border:1px solid #d6c9b8"></span>brak
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded" style="background:#fde68a"></span>1
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded" style="background:#fbbf24"></span>2
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded" style="background:#f59e0b"></span>3-4
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-3 w-5 rounded" style="background:#d97706"></span>5+
    </span>
  </div>
</div>

<script>
  const wrap = document.getElementById('woj-map-wrap')!;
  const tooltip = document.getElementById('woj-tooltip')!;
  const tooltipName = document.getElementById('woj-tooltip-name')!;
  const tooltipCount = document.getElementById('woj-tooltip-count')!;
  const regions = document.querySelectorAll<SVGGElement>('.woj-region');
  const cityInput = document.getElementById('city-search') as HTMLInputElement;

  let activeWoj = '';

  regions.forEach((g) => {
    const path = g.querySelector('path')!;
    const origFill = path.getAttribute('fill')!;

    g.addEventListener('mouseenter', (e) => {
      const name = g.dataset.name ?? '';
      const count = g.dataset.count ?? '0';
      tooltipName.textContent = name;
      tooltipCount.textContent = `${count} ${Number(count) === 1 ? 'targ' : Number(count) < 5 ? 'targi' : 'targów'}`;

      const rect = wrap.getBoundingClientRect();
      const gRect = g.getBoundingClientRect();
      const cx = gRect.left + gRect.width / 2 - rect.left;
      const cy = gRect.top - rect.top;

      tooltip.style.left = `${cx}px`;
      tooltip.style.top = `${cy}px`;
      tooltip.classList.remove('hidden');

      if (g.dataset.slug !== activeWoj) {
        path.setAttribute('fill', '#92400e');
        path.style.opacity = '0.85';
      }
    });

    g.addEventListener('mouseleave', () => {
      tooltip.classList.add('hidden');
      if (g.dataset.slug !== activeWoj) {
        path.setAttribute('fill', origFill);
        path.style.opacity = '1';
      }
    });

    g.addEventListener('click', () => {
      const slug = g.dataset.slug ?? '';

      if (activeWoj === slug) {
        // deselect
        activeWoj = '';
        regions.forEach((rg) => {
          const p = rg.querySelector('path')!;
          const orig = p.getAttribute('fill')!;
          p.style.opacity = '1';
        });
        if (cityInput) {
          cityInput.value = '';
          cityInput.dispatchEvent(new Event('input'));
        }
        return;
      }

      activeWoj = slug;

      // highlight selected, dim others
      regions.forEach((rg) => {
        const p = rg.querySelector('path')!;
        if (rg.dataset.slug === slug) {
          p.setAttribute('fill', '#b45309');
          p.style.opacity = '1';
        } else {
          p.style.opacity = '0.35';
        }
      });

      // filter fair list by typing voivodeship slug into search
      if (cityInput) {
        cityInput.value = slug;
        cityInput.dispatchEvent(new Event('input'));
        // scroll to list
        document.getElementById('fair-list')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
