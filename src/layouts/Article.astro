---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author?: string;
  tags?: string[];
  canonical?: string;
}

const { title, description, publishedAt, updatedAt, author = 'Redakcja gdziestarocie.pl', tags, canonical } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  ...(updatedAt ? { dateModified: updatedAt.toISOString() } : {}),
  author: { '@type': 'Organization', name: 'gdziestarocie.pl' },
  publisher: { '@type': 'Organization', name: 'gdziestarocie.pl', url: 'https://gdziestarocie.pl' },
};
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd} og={{ type: 'article' }}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      {tags?.length && (
        <div class="mb-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-medium text-brand-800">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-3xl font-bold leading-tight text-stone-900 sm:text-4xl">{title}</h1>
      <p class="mt-3 text-sm text-stone-500">
        {formattedDate} &middot; {author}
      </p>
    </header>

    <div class="prose prose-stone max-w-none prose-headings:font-bold prose-a:text-brand-700 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
      <slot />
    </div>
  </article>
</Base>
