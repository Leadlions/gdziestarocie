---
import '../styles/global.css';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  og?: { title?: string; description?: string; type?: string };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbs?: Breadcrumb[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  og = {},
  jsonLd,
  breadcrumbs,
} = Astro.props;

const siteName = 'gdziestarocie.pl';
const ogTitle = og.title ?? title;
const ogDescription = og.description ?? description;
const ogType = og.type ?? 'website';

const breadcrumbSchema = breadcrumbs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Strona główna', item: 'https://gdziestarocie.pl/' },
        ...breadcrumbs.map((b, i) => ({
          '@type': 'ListItem',
          position: i + 2,
          name: b.name,
          item: b.url,
        })),
      ],
    }
  : null;

const allSchemas = [
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
];

const CATEGORIES = [
  { name: 'Antyki', slug: 'antyki' },
  { name: 'Meble vintage', slug: 'meble' },
  { name: 'Ceramika i porcelana', slug: 'ceramika' },
  { name: 'Biżuteria i zegarki', slug: 'bizuteria' },
  { name: 'Monety i banknoty', slug: 'numizmatyka' },
  { name: 'Książki i mapy', slug: 'ksiazki' },
  { name: 'Zabawki vintage', slug: 'zabawki' },
  { name: 'Militaria', slug: 'militaria' },
  { name: 'Obrazy i grafiki', slug: 'obrazy' },
  { name: 'Winyle i audio', slug: 'winyle' },
];

const CITIES = [
  { name: 'Warszawa', slug: 'warszawa' },
  { name: 'Kraków', slug: 'krakow' },
  { name: 'Gdańsk', slug: 'gdansk' },
  { name: 'Wrocław', slug: 'wroclaw' },
  { name: 'Poznań', slug: 'poznan' },
  { name: 'Łódź', slug: 'lodz' },
  { name: 'Katowice', slug: 'katowice' },
  { name: 'Szczecin', slug: 'szczecin' },
  { name: 'Lublin', slug: 'lublin' },
  { name: 'Bydgoszcz', slug: 'bydgoszcz' },
  { name: 'Białystok', slug: 'bialystok' },
  { name: 'Rzeszów', slug: 'rzeszow' },
  { name: 'Olsztyn', slug: 'olsztyn' },
  { name: 'Kielce', slug: 'kielce' },
];
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {allSchemas.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(allSchemas)} />
    )}
  </head>
  <body class="bg-white text-stone-800 antialiased">

    <!-- HEADER -->
    <header class="sticky top-0 z-50 border-b border-stone-200 bg-white/95 backdrop-blur-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">

        <!-- Logo -->
        <a href="/" class="flex flex-col leading-none">
          <span class="text-[10px] font-light uppercase tracking-[0.35em] text-stone-400">gdzie</span>
          <span class="text-[19px] font-extrabold tracking-tight text-brand-800">starocie</span>
        </a>

        <!-- Nav + hamburger -->
        <div class="flex items-center gap-2">
          <nav class="hidden items-center gap-0.5 lg:flex">

            <!-- Kategorie dropdown -->
            <div class="group relative">
              <button class="flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-50 hover:text-brand-700">
                Kategorie
                <svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="invisible absolute left-0 top-full z-50 mt-1 w-60 rounded-xl border border-stone-100 bg-white p-2 opacity-0 shadow-xl transition-all duration-150 group-hover:visible group-hover:opacity-100">
                <p class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-stone-400">Co szukasz?</p>
                {CATEGORIES.map((c) => (
                  <a href={`/targi/kategoria/${c.slug}/`} class="block rounded-lg px-3 py-2 text-sm text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-700">
                    {c.name}
                  </a>
                ))}
              </div>
            </div>

            <!-- Miasta dropdown -->
            <div class="group relative">
              <button class="flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-50 hover:text-brand-700">
                Miasta
                <svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="invisible absolute left-0 top-full z-50 mt-1 w-44 rounded-xl border border-stone-100 bg-white p-2 opacity-0 shadow-xl transition-all duration-150 group-hover:visible group-hover:opacity-100">
                <p class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-stone-400">Wybierz miasto</p>
                {CITIES.map((c) => (
                  <a href={`/targi/miasto/${c.slug}/`} class="block rounded-lg px-3 py-2 text-sm text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-700">
                    {c.name}
                  </a>
                ))}
              </div>
            </div>

            <a href="/blog/" class="rounded-md px-3 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-50 hover:text-brand-700">
              Blog
            </a>
          </nav>

          <!-- Hamburger -->
          <button
            id="menu-toggle"
            class="rounded-md p-2 text-stone-600 transition-colors hover:bg-stone-100 lg:hidden"
            aria-label="Otwórz menu"
          >
            <svg id="icon-open" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="icon-close" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-stone-100 bg-white px-4 pb-5 lg:hidden">
        <div class="mt-3 space-y-0.5">
          <p class="px-3 pb-1 pt-3 text-xs font-semibold uppercase tracking-wider text-stone-400">Kategorie</p>
          <div class="grid grid-cols-2 gap-0.5">
            {CATEGORIES.map((c) => (
              <a href={`/targi/kategoria/${c.slug}/`} class="rounded-lg px-3 py-2 text-sm text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-700">
                {c.name}
              </a>
            ))}
          </div>
          <p class="px-3 pb-1 pt-4 text-xs font-semibold uppercase tracking-wider text-stone-400">Miasta</p>
          <div class="grid grid-cols-2 gap-0.5">
            {CITIES.map((c) => (
              <a href={`/targi/miasto/${c.slug}/`} class="rounded-lg px-3 py-2 text-sm text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-700">
                {c.name}
              </a>
            ))}
          </div>
          <div class="mt-3 border-t border-stone-100 pt-3">
            <a href="/blog/" class="block rounded-lg px-3 py-2 text-sm text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-700">Blog</a>
          </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 border-t border-stone-200 bg-stone-50">
      <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
          <div>
            <p class="text-sm font-semibold text-stone-800">Kategorie</p>
            <ul class="mt-3 space-y-2 text-sm text-stone-600">
              {CATEGORIES.map((c) => (
                <li><a href={`/targi/kategoria/${c.slug}/`} class="hover:text-brand-700">{c.name}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <p class="text-sm font-semibold text-stone-800">Miasta</p>
            <ul class="mt-3 space-y-2 text-sm text-stone-600">
              {CITIES.map((c) => (
                <li><a href={`/targi/miasto/${c.slug}/`} class="hover:text-brand-700">{c.name}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <p class="text-sm font-semibold text-stone-800">Portal</p>
            <ul class="mt-3 space-y-2 text-sm text-stone-600">
              <li><a href="/blog/" class="hover:text-brand-700">Blog</a></li>
              <li><a href="/targi/" class="hover:text-brand-700">Wszystkie targi</a></li>
            </ul>
          </div>
          <div>
            <p class="text-sm font-semibold text-stone-800">gdziestarocie.pl</p>
            <p class="mt-3 text-xs leading-relaxed text-stone-500">
              Kompletny kalendarz targów staroci i antyków w Polsce. Opinie, wzmianki medialne i terminarz w jednym miejscu.
            </p>
          </div>
        </div>
        <div class="mt-8 border-t border-stone-200 pt-6 text-center text-xs text-stone-400">
          &copy; {new Date().getFullYear()} gdziestarocie.pl — Wszelkie prawa zastrzeżone.
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden', !isHidden);
        iconOpen?.classList.toggle('hidden', isHidden ?? false);
        iconClose?.classList.toggle('hidden', !isHidden);
      });
    </script>
  </body>
</html>
