---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<Base
  title="Blog o starociach i antykach – gdziestarocie.pl"
  description="Poradniki dla kolekcjonerów, historia antyków i ciekawostki ze świata targów staroci w Polsce. Czytaj i kolekcjonuj mądrze."
>
  <section class="border-b border-stone-100 bg-gradient-to-b from-brand-50 to-white px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-4xl">
      <h1 class="text-3xl font-bold text-stone-900 sm:text-4xl">Blog</h1>
      <p class="mt-3 text-stone-600">
        Poradniki, historia i ciekawostki ze świata antyków i targów staroci.
      </p>
    </div>
  </section>

  <section class="px-4 py-10 sm:px-6">
    <div class="mx-auto max-w-4xl">
      {posts.length === 0 ? (
        <p class="text-stone-500">Wkrótce pojawią się pierwsze wpisy. Wróć za chwilę!</p>
      ) : (
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              href={`/blog/${post.slug}/`}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
